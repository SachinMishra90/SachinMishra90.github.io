{
  "name": "Sachin Tech Pro Video Editor",
  "short_name": "SachinTech",
  "start_url": "/index.html",
  "display": "standalone",
  "background_color": "#0a0a0a",
  "theme_color": "#00f2fe",
  "icons": [
    {
      "src": "https://cdn-icons-png.flaticon.com/512/711/711245.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ]
}
{
async function compressImage()
{
  const fileInput = document.getElementById('imageInput');
  const targetKB = parseFloat(document.getElementById('targetSize').value);
  
  if (!fileInput.files[0]) {
    alert("Pehle image select karo!");
    return;
  }

  const file = fileInput.files[0];
  const originalSize = (file.size / 1024).toFixed(2);

  // Show original info
  document.getElementById('result').innerHTML = `Original Size: ${originalSize} KB`;

  try {
    // Pehle library load karo (CDN se)
    // Ya phir direct vanilla canvas method bhi use kar sakte hain

    let compressedFile = file;
    let quality = 0.8;
    let maxWidth = 1200;

    // Iterative compression to reach target size
    while ((compressedFile.size / 1024) > targetKB && quality > 0.1)
    {
      const options = {
        maxSizeMB: targetKB / 1024,
        maxWidthOrHeight: maxWidth,
        useWebWorker: true,
        quality: quality
      };

      compressedFile = await imageCompression(file, options);  // library use karega
      quality -= 0.05;
      maxWidth = Math.floor(maxWidth * 0.9);   // resize bhi karte jao
    }

    // Preview + Download
    const url = URL.createObjectURL(compressedFile);
    const finalSize = (compressedFile.size / 1024).toFixed(2);

    document.getElementById('preview').innerHTML = `
      <img src="${url}" width="300">
      <p>Compressed Size: <strong>${finalSize} KB</strong> 
         (${((1 - compressedFile.size/file.size)*100).toFixed(1)}% reduced)</p>
      <a href="${url}" download="compressed-image.jpg">Download Compressed Image</a>
    `;

  } 
catch (error)
{
    console.error(error);
    alert("Compression mein error aaya. Chhoti image try karo ya quality kam karo.");
  }
}
