// ==================== IMAGE COMPRESSOR ====================

async function startCompression() {
    const fileInput = document.getElementById('imageInput');
    const targetKB = parseFloat(document.getElementById('targetSize').value) || 10;
    const resultDiv = document.getElementById('compression-result');

    if (!fileInput.files || !fileInput.files[0]) {
        alert("❌ Pehle image select karo!");
        return;
    }

    const originalFile = fileInput.files[0];
    const originalSize = (originalFile.size / 1024).toFixed(2);

    resultDiv.innerHTML = `<p><b>Original:</b> ${originalSize} KB</p><p>Compressing... thoda time lag sakta hai</p>`;

    try {
        // Load library if not loaded
        if (typeof imageCompression === "undefined") {
            await loadImageCompressionLibrary();
        }

        let compressedFile = originalFile;
        let quality = 0.8;
        let maxWidth = 1400;

        // Iterative Compression
        while ((compressedFile.size / 1024) > targetKB && quality > 0.15) {
            const options = {
                maxSizeMB: (targetKB * 1.1) / 1024,   // thoda margin
                maxWidthOrHeight: maxWidth,
                useWebWorker: true,
                quality: quality,
                initialQuality: quality
            };

            compressedFile = await imageCompression(originalFile, options);

            quality -= 0.07;
            maxWidth = Math.floor(maxWidth * 0.93);
        }

        const finalSize = (compressedFile.size / 1024).toFixed(2);
        const reduction = ((1 - compressedFile.size / originalFile.size) * 100).toFixed(1);

        const imageUrl = URL.createObjectURL(compressedFile);

        resultDiv.innerHTML = `
            <h3>✅ Compression Ho Gayi!</h3>
            <p><b>Original:</b> ${originalSize} KB</p>
            <p><b>Compressed:</b> <strong>\( {finalSize} KB</strong> ( \){reduction}% reduced)</p>
            
            <img src="${imageUrl}" style="max-width: 100%; max-height: 400px; border-radius: 10px; margin: 15px 0;">
            
            <br><br>
            <a href="${imageUrl}" download="compressed_sachintech.jpg" 
               style="background:#00f2fe; color:black; padding:14px 24px; text-decoration:none; border-radius:8px; font-weight:bold;">
               📥 Download Compressed Image
            </a>
        `;

    } catch (error) {
        console.error(error);
        resultDiv.innerHTML = `<p style="color:red;">❌ Error: ${error.message || "Kuch problem hui hai"}</p>
                               <p>Chhoti image try karo ya target size badha do.</p>`;
    }
}

// Library Loader
function loadImageCompressionLibrary() {
    return new Promise((resolve, reject) => {
        if (typeof imageCompression !== "undefined") {
            resolve();
            return;
        }

        const script = document.createElement('script');
        script.src = "https://cdn.jsdelivr.net/npm/browser-image-compression@1.0.0/dist/browser-image-compression.js";
        script.onload = resolve;
        script.onerror = () => reject(new Error("Library load nahi hui"));
        document.head.appendChild(script);
    });
}
